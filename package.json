{
  "name": "@skillswap/workspace",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm --workspace frontend run build",
    "build:frontend": "npm --workspace frontend run build",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "eslint \"frontend/src/App.tsx\" \"frontend/src/main.tsx\" \"frontend/src/app/**/*.{ts,tsx}\" \"frontend/src/providers/**/*.{ts,tsx}\" \"frontend/src/features/{landing,settings,calls,chess,whiteboard,profile}/**/*.{ts,tsx}\" \"frontend/src/pages/{landing,settings,profile}/**/*.{ts,tsx}\"",
    "lint:backend": "eslint \"backend/src/**/*.ts\" \"backend/tests/**/*.ts\" \"packages/shared/src/**/*.ts\"",
    "lint:fix": "npm run lint:frontend -- --fix && npm run lint:backend -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm run test:backend",
    "test:frontend": "npm --workspace frontend run test",
    "test:backend": "npm --workspace backend run test",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "npm --workspace frontend run typecheck",
    "typecheck:backend": "npm --workspace backend run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.0",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.2"
  }
}
