# Copy to `.env.test` and adjust if you want file-based test secrets (optional).
# Vitest also sets NODE_ENV=test and ADMIN_SECRET_KEY via vitest.config.ts.
#
# When NODE_ENV=test, server/config/livekit.config.ts and supabase.config.ts
# supply safe placeholders if these are unset.

# ADMIN_SECRET_KEY=test-admin-key

# Optional overrides for integration tests that hit real services:
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
