{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@shared/*": ["../packages/shared/src/*"]
    }
  },
  "include": ["src", "tests", "vitest.config.ts"],
  "ts-node": {
    "esm": true
  }
}
